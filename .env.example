# ============================================
# AgentForge 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================

# ----------------
# LLM API 配置
# ----------------
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Azure OpenAI
AZURE_API_KEY=your-azure-api-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com
AZURE_API_VERSION=2024-02-15-preview

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 其他 LLM 提供商
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# 智谱 AI
ZHIPUAI_API_KEY=your-zhipuai-api-key
ZHIPUAI_API_BASE=https://open.bigmodel.cn/api/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Moonshot
MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# 默认模型配置
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# ----------------
# 数据库配置
# ----------------
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=agentforge
DATABASE_URL=postgresql+asyncpg://agentforge:your-secure-password@localhost:5432/agentforge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ----------------
# 应用配置
# ----------------
# API 服务
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
SECRET_KEY=your-secret-key-for-jwt-here

# 前端服务
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------
# 功能开关
# ----------------
ENABLE_MULTI_AGENT=true
ENABLE_WORKFLOW=true
ENABLE_MEMORY=true
ENABLE_TOOL_EXECUTION=true
ENABLE_CODE_SANDBOX=false

# ----------------
# 日志配置
# ----------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------
# 安全配置
# ----------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=60
